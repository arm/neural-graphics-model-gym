{
    "config_schema_version": {
        "default": "8",
        "description": "Config schema version. Used to check compatibility.",
        "type": "string"
    },
    "model": {
        "discriminator": {
            "propertyName": "model_source"
        },
        "oneOf": [
            {
                "discriminator": {
                    "propertyName": "name"
                },
                "oneOf": [
                    {
                        "name": {
                            "const": "nss",
                            "type": "string"
                        },
                        "version": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "Model version"
                        },
                        "model_source": {
                            "const": "prebuilt",
                            "type": "string"
                        },
                        "scale": {
                            "default": 2.0,
                            "description": "Upscale parameter for the NSS model. NSS v1 train/eval supports numeric scale values greater than 1.0.",
                            "exclusiveMinimum": 1.0,
                            "type": "number"
                        },
                        "recurrent_samples": {
                            "description": "Number of recurrent samples",
                            "exclusiveMinimum": 1,
                            "type": "integer"
                        },
                        "quality": {
                            "anyOf": [
                                {
                                    "enum": [
                                        "high",
                                        "mid",
                                        "low"
                                    ],
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "NSS v1 quality mode."
                        },
                        "normalize_lr_motion": {
                            "anyOf": [
                                {
                                    "type": "boolean"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "Whether NSS dataset loading normalizes low-resolution motion vectors. If omitted, NSS v0.1 keeps the legacy normalized default and NSS v1 preserves raw low-resolution motion."
                        },
                        "gt_history_augmentation": {
                            "default": true,
                            "description": "Enable NSS v1 training-time recurrent history augmentation. When enabled, the first recurrent frame can initialize history from ground truth instead of the reset history buffer.",
                            "type": "boolean"
                        },
                        "gt_history_augmentation_chance": {
                            "default": 30.0,
                            "description": "Percent chance per batch element of replacing first-frame recurrent history with ground truth when gt_history_augmentation is enabled.",
                            "maximum": 100.0,
                            "minimum": 0.0,
                            "type": "number"
                        }
                    },
                    {
                        "name": {
                            "const": "nfru",
                            "type": "string"
                        },
                        "version": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "Model version"
                        },
                        "model_source": {
                            "const": "prebuilt",
                            "type": "string"
                        },
                        "scale_factor": {
                            "default": 2.0,
                            "description": "Interpolation scale factor for the NFRU model. Only 2 (or 2.0) is currently supported.",
                            "maximum": 2.0,
                            "minimum": 2.0,
                            "type": "number"
                        },
                        "legacy_nfru_capture_paths": {
                            "description": "Path substrings identifying legacy NFRU captures that should use the old window stride behavior.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "dynamic_mask_is_runtime_accurate": {
                            "default": false,
                            "description": "Whether to use runtime-accurate dynamic masks in NFRU preprocessing and motion-vector warping.",
                            "type": "boolean"
                        },
                        "mv_similarity_threshold": {
                            "anyOf": [
                                {
                                    "minimum": 0.0,
                                    "type": "number"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "Motion-vector similarity threshold used by NFRU dynamic masks. Defaults to a value specific to the selected dynamic mask implementation."
                        }
                    }
                ]
            },
            {
                "name": {
                    "description": "Model name",
                    "type": "string"
                },
                "version": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Model version"
                },
                "model_source": {
                    "const": "custom",
                    "type": "string"
                }
            }
        ]
    },
    "dataset": {
        "name": {
            "description": "Dataset name",
            "type": "string"
        },
        "version": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Dataset version"
        },
        "path": {
            "train": {
                "anyOf": [
                    {
                        "format": "path",
                        "type": "string"
                    },
                    {
                        "type": "null"
                    }
                ],
                "default": null,
                "description": "Train dataset directory path"
            },
            "validation": {
                "anyOf": [
                    {
                        "format": "path",
                        "type": "string"
                    },
                    {
                        "type": "null"
                    }
                ],
                "default": null,
                "description": "Validation dataset directory path"
            },
            "test": {
                "anyOf": [
                    {
                        "format": "path",
                        "type": "string"
                    },
                    {
                        "type": "null"
                    }
                ],
                "default": null,
                "description": "Test dataset directory path"
            }
        },
        "color_preprocessing": {
            "anyOf": [
                {
                    "train": {
                        "anyOf": [
                            {
                                "pipeline": {
                                    "description": "Ordered color stages. Nested lists indicate mutually exclusive stages to sample from during random-effects training.",
                                    "items": {
                                        "anyOf": [
                                            {
                                                "type": "string"
                                            },
                                            {},
                                            {
                                                "items": {
                                                    "anyOf": [
                                                        {
                                                            "type": "string"
                                                        },
                                                        {}
                                                    ]
                                                },
                                                "type": "array"
                                            }
                                        ]
                                    },
                                    "type": "array"
                                },
                                "exposure": {
                                    "anyOf": [
                                        {
                                            "type": "number"
                                        },
                                        {
                                            "const": "auto",
                                            "type": "string"
                                        },
                                        {
                                            "items": {
                                                "type": "number"
                                            },
                                            "maxItems": 2,
                                            "minItems": 2,
                                            "type": "array"
                                        }
                                    ],
                                    "default": 2.0,
                                    "description": "Fixed exposure, \"auto\", or a two-item range for resampling."
                                },
                                "auto_exposure_key_value": {
                                    "default": 1.0,
                                    "description": "Key value used when exposure is set to auto.",
                                    "type": "number"
                                },
                                "auto_exposure_variance": {
                                    "anyOf": [
                                        {},
                                        {
                                            "type": "null"
                                        }
                                    ],
                                    "default": null,
                                    "description": "Optional per-time-index multiplier applied to auto exposure."
                                }
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "default": null,
                        "description": "Color preprocessing applied to training data."
                    },
                    "validation": {
                        "anyOf": [
                            {
                                "pipeline": {
                                    "description": "Ordered color stages. Nested lists indicate mutually exclusive stages to sample from during random-effects training.",
                                    "items": {
                                        "anyOf": [
                                            {
                                                "type": "string"
                                            },
                                            {},
                                            {
                                                "items": {
                                                    "anyOf": [
                                                        {
                                                            "type": "string"
                                                        },
                                                        {}
                                                    ]
                                                },
                                                "type": "array"
                                            }
                                        ]
                                    },
                                    "type": "array"
                                },
                                "exposure": {
                                    "anyOf": [
                                        {
                                            "type": "number"
                                        },
                                        {
                                            "const": "auto",
                                            "type": "string"
                                        },
                                        {
                                            "items": {
                                                "type": "number"
                                            },
                                            "maxItems": 2,
                                            "minItems": 2,
                                            "type": "array"
                                        }
                                    ],
                                    "default": 2.0,
                                    "description": "Fixed exposure, \"auto\", or a two-item range for resampling."
                                },
                                "auto_exposure_key_value": {
                                    "default": 1.0,
                                    "description": "Key value used when exposure is set to auto.",
                                    "type": "number"
                                },
                                "auto_exposure_variance": {
                                    "anyOf": [
                                        {},
                                        {
                                            "type": "null"
                                        }
                                    ],
                                    "default": null,
                                    "description": "Optional per-time-index multiplier applied to auto exposure."
                                }
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "default": null,
                        "description": "Color preprocessing applied to validation data."
                    },
                    "test": {
                        "anyOf": [
                            {
                                "pipeline": {
                                    "description": "Ordered color stages. Nested lists indicate mutually exclusive stages to sample from during random-effects training.",
                                    "items": {
                                        "anyOf": [
                                            {
                                                "type": "string"
                                            },
                                            {},
                                            {
                                                "items": {
                                                    "anyOf": [
                                                        {
                                                            "type": "string"
                                                        },
                                                        {}
                                                    ]
                                                },
                                                "type": "array"
                                            }
                                        ]
                                    },
                                    "type": "array"
                                },
                                "exposure": {
                                    "anyOf": [
                                        {
                                            "type": "number"
                                        },
                                        {
                                            "const": "auto",
                                            "type": "string"
                                        },
                                        {
                                            "items": {
                                                "type": "number"
                                            },
                                            "maxItems": 2,
                                            "minItems": 2,
                                            "type": "array"
                                        }
                                    ],
                                    "default": 2.0,
                                    "description": "Fixed exposure, \"auto\", or a two-item range for resampling."
                                },
                                "auto_exposure_key_value": {
                                    "default": 1.0,
                                    "description": "Key value used when exposure is set to auto.",
                                    "type": "number"
                                },
                                "auto_exposure_variance": {
                                    "anyOf": [
                                        {},
                                        {
                                            "type": "null"
                                        }
                                    ],
                                    "default": null,
                                    "description": "Optional per-time-index multiplier applied to auto exposure."
                                }
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "default": null,
                        "description": "Color preprocessing applied to test data."
                    }
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Required lowercase color pipeline configuration for train, validation, and test."
        },
        "exposure": {
            "anyOf": [
                {
                    "minimum": 0.0,
                    "type": "number"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Training dataset exposure value"
        },
        "tonemapper": {
            "anyOf": [
                {
                    "description": "Supported modes for tone mapping.",
                    "enum": [
                        "reinhard",
                        "karis",
                        "log",
                        "log10",
                        "log_norm",
                        "aces"
                    ],
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Tonemapping method for dataset"
        },
        "health_check": {
            "description": "Run health check on given dataset. health_check() must be implemented in the Dataset.",
            "type": "boolean"
        },
        "gt_augmentation": {
            "description": "Enable dataset augmentations e.g flips, rotations",
            "type": "boolean"
        },
        "num_workers": {
            "description": "Number of dataloader workers to use",
            "minimum": 0,
            "type": "integer"
        },
        "prefetch_factor": {
            "description": "Number of batches loaded in advance by each dataloader worker. Used only if num_workers > 0",
            "minimum": 0,
            "type": "integer"
        },
        "align_data": {
            "default": true,
            "description": "Whether to align loaded dataset features to the model input set.",
            "type": "boolean"
        },
        "extension": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": ".safetensors",
            "description": "File extension for dataset files to be found (grep) and loaded, e.g. '.safetensors', '.jpg'. Defaults to .safetensors."
        }
    },
    "output": {
        "dir": {
            "description": "Directory path for storing training output",
            "format": "path",
            "type": "string"
        },
        "export_frame_png": {
            "description": "Export frames to PNG (for visualization) during model evaluation",
            "type": "boolean"
        },
        "tensorboard_output_dir": {
            "anyOf": [
                {
                    "format": "path",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Output directory for tensorboard logs. If None is passed, disable tensorboard"
        },
        "export": {
            "dynamic_shape": {
                "description": "Enable dynamic input shapes for the exported model ",
                "type": "boolean"
            },
            "vgf_static_input_shape": {
                "anyOf": [
                    {
                        "description": "One or more static VGF input shape definition (4 positive ints each)",
                        "items": {
                            "items": {
                                "exclusiveMinimum": 0,
                                "type": "integer"
                            },
                            "maxItems": 4,
                            "minItems": 4,
                            "type": "array"
                        },
                        "minItems": 1,
                        "type": "array"
                    },
                    {
                        "type": "null"
                    }
                ],
                "default": null
            },
            "vgf_output_dir": {
                "description": "Output directory for the VGF file",
                "format": "path",
                "type": "string"
            }
        }
    },
    "train": {
        "batch_size": {
            "description": "Number of samples processed together in one pass before updating model weights",
            "minimum": 1,
            "type": "integer"
        },
        "seed": {
            "description": "Seed for random number generation",
            "minimum": 0,
            "type": "integer"
        },
        "perform_validate": {
            "description": "Perform validation at the end of specific training epochs, as set by the validate_frequency field.",
            "type": "boolean"
        },
        "compile": {
            "default": false,
            "description": "Enable torch.compile for the training step.",
            "type": "boolean"
        },
        "validate_frequency": {
            "anyOf": [
                {
                    "type": "integer"
                },
                {
                    "items": {
                        "type": "integer"
                    },
                    "type": "array"
                }
            ],
            "default": 1,
            "description": "For a single int, N, validate every N epochs. For a List of ints, run validation after each epoch in the List. If using with `perform_validate=true`, ensure that at least one validation pass will run within the total number of epochs, otherwise a ValueError is raised."
        },
        "fp32": {
            "number_of_epochs": {
                "description": "Number of epochs",
                "minimum": 1,
                "type": "integer"
            },
            "checkpoints": {
                "dir": {
                    "description": "Save directory for checkpoints",
                    "format": "path",
                    "type": "string"
                }
            },
            "lr_scheduler": {
                "description": "The Learning Rate Scheduler used during training. Can be one of: cosine_annealing, exponential_step, static",
                "discriminator": {
                    "propertyName": "type"
                },
                "oneOf": [
                    {
                        "type": {
                            "const": "cosine_annealing",
                            "type": "string"
                        },
                        "warmup_percentage": {
                            "description": "Proportion of training steps to linearly warm up the learning rate",
                            "exclusiveMaximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        },
                        "min_lr": {
                            "description": "Minimum learning rate reached after cosine decay.",
                            "maximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        }
                    },
                    {
                        "type": {
                            "const": "exponential_step",
                            "type": "string"
                        },
                        "decay_rate": {
                            "description": "Learning rate decay rate. Decay applied every step_size steps.",
                            "maximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        },
                        "decay_factor": {
                            "description": "Divisor for total number of iterations. The larger the value, the quicker the decay i.e. step_size = (epochs * dataset_size) / decay_factor",
                            "minimum": 1,
                            "type": "integer"
                        }
                    },
                    {
                        "type": {
                            "const": "static",
                            "type": "string"
                        }
                    }
                ]
            },
            "optimizer": {
                "optimizer_type": {
                    "description": "Optimizer type to use during training. Choose from: adam_w, lars_adam, adam",
                    "type": "string"
                },
                "learning_rate": {
                    "description": "The learning rate. Scheduler may override this value",
                    "exclusiveMinimum": 0.0,
                    "maximum": 1.0,
                    "type": "number"
                },
                "eps": {
                    "anyOf": [
                        {
                            "exclusiveMinimum": 0.0,
                            "type": "number"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional epsilon value for optimizers that support it."
                }
            }
        },
        "qat": {
            "number_of_epochs": {
                "description": "Number of epochs",
                "minimum": 1,
                "type": "integer"
            },
            "checkpoints": {
                "dir": {
                    "description": "Save directory for checkpoints",
                    "format": "path",
                    "type": "string"
                }
            },
            "lr_scheduler": {
                "description": "The Learning Rate Scheduler used during training. Can be one of: cosine_annealing, exponential_step, static",
                "discriminator": {
                    "propertyName": "type"
                },
                "oneOf": [
                    {
                        "type": {
                            "const": "cosine_annealing",
                            "type": "string"
                        },
                        "warmup_percentage": {
                            "description": "Proportion of training steps to linearly warm up the learning rate",
                            "exclusiveMaximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        },
                        "min_lr": {
                            "description": "Minimum learning rate reached after cosine decay.",
                            "maximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        }
                    },
                    {
                        "type": {
                            "const": "exponential_step",
                            "type": "string"
                        },
                        "decay_rate": {
                            "description": "Learning rate decay rate. Decay applied every step_size steps.",
                            "maximum": 1.0,
                            "minimum": 0.0,
                            "type": "number"
                        },
                        "decay_factor": {
                            "description": "Divisor for total number of iterations. The larger the value, the quicker the decay i.e. step_size = (epochs * dataset_size) / decay_factor",
                            "minimum": 1,
                            "type": "integer"
                        }
                    },
                    {
                        "type": {
                            "const": "static",
                            "type": "string"
                        }
                    }
                ]
            },
            "optimizer": {
                "optimizer_type": {
                    "description": "Optimizer type to use during training. Choose from: adam_w, lars_adam, adam",
                    "type": "string"
                },
                "learning_rate": {
                    "description": "The learning rate. Scheduler may override this value",
                    "exclusiveMinimum": 0.0,
                    "maximum": 1.0,
                    "type": "number"
                },
                "eps": {
                    "anyOf": [
                        {
                            "exclusiveMinimum": 0.0,
                            "type": "number"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional epsilon value for optimizers that support it."
                }
            }
        },
        "loss_fn": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Loss function to use. Choose from: loss_v0_1, loss_v1, lpips_spatial_loss_v1"
        },
        "loss_args": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Optional dictionary of arguments to pass to the loss function"
        }
    },
    "processing": {
        "shader_accurate": {
            "description": "Use slang shaders that match deployment shaders",
            "type": "boolean"
        }
    },
    "metrics": {
        "anyOf": [
            {
                "items": {
                    "type": "string"
                },
                "type": "array"
            },
            {
                "train": {
                    "anyOf": [
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Metric names to instantiate during training."
                },
                "val": {
                    "anyOf": [
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Metric names to instantiate during validation."
                },
                "test": {
                    "anyOf": [
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Metric names to instantiate during evaluation/test."
                }
            },
            {
                "type": "null"
            }
        ],
        "default": null,
        "description": "Metric names to instantiate. Provide a list to use the same metrics for train/val/test, or an object with train/val/test lists. Temporal metrics are replaced with streaming variants during evaluation."
    }
}